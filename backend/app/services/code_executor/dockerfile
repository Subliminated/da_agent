# Create a container to host a code interpreter for my agent to run and execute code.
FROM python:3.11-slim

WORKDIR /app
COPY ./app.py /app/app.py

RUN pip install --no-cache-dir \
    flask==3.0.3 \
    pandas==2.2.3 \
    numpy==1.26.4 \
    matplotlib==3.8.4 \
    seaborn==0.13.2 \
    openpyxl==3.1.5 \
    scikit-learn==1.5.2 \
    joblib==1.4.2

# Set the working directory inside the container
WORKDIR /app

# Create a directory for data to mount a point for csv data
RUN mkdir /data

# Expose the port the app runs on (5000)
EXPOSE 8888

# Run the application on docker start
CMD ["python", "app.py"]

